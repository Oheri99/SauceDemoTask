{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    "strict": false,
    "jsx": "react-jsx",

    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",

    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
